# Copy this file to .env.local and fill in your credentials

# ── Supabase (optional — app runs in demo mode without this) ──────────────────
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Anthropic (optional — enables AI recipe suggestions) ─────────────────────
# Get your key from: https://console.anthropic.com/settings/keys
# Model used: claude-haiku-4-5-20251001 (~$0.0005 per recipe request)
ANTHROPIC_API_KEY=sk-ant-api03-...
