# ────────────────────────────────────────────────────────────────────────────
# FreshTrack v2 — Environment Variables
#
# Local development:
#   Copy this file to .env.local and fill in values.
#   The app reads from .env.local automatically via Vite.
#
# Vercel production:
#   Set each variable in Vercel > Project Settings > Environment Variables.
# ────────────────────────────────────────────────────────────────────────────

# ── Database: Turso (libSQL / SQLite) ─────────────────────────────────────
#
# Local dev: use a local SQLite file (no auth token needed)
#   TURSO_DATABASE_URL=file:local.db
#
# Production: create a free Turso database at https://turso.tech
#   turso db create freshtrack
#   turso db show freshtrack   # copy the libsql:// URL
#   turso db tokens create freshtrack
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# ── Authentication (better-auth) ─────────────────────────────────────────���
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
# For Vercel: leave blank — VERCEL_URL is used automatically
# For local dev: http://localhost:5173
BETTER_AUTH_URL=http://localhost:5173

# ── Anthropic API (AI recipe suggestions) ────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Kassalapp (Norwegian grocery pricing) ────────────────────────────────
# Free API key at: https://kassal.app/api
KASSALAPP_API_KEY=

# ── Vite public env (exposed to browser) ─────────────────────────────────
VITE_APP_URL=http://localhost:5173
